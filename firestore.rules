// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: /comments/{commentId}
// Document ID: auto-generated
// Fields:
//   - text: string (required, 1-500 chars) - The content of the comment
//   - authorName: string (required, 1-50 chars) - Name of the sender
//   - authorUid: string (required) - UID of the sender
//   - timestamp: timestamp (required) - When the comment was sent
//   - language: string (optional) - The language of the comment
//
// Collection: /liveState/global
// Document ID: global
// Fields:
//   - isLive: bool - Whether the session is live
//   - currentMusic: string - Current music track
//   - currentAd: string - Current active advertisement
//   - zoomLink: string - Link to join the zoom meeting
//   - activeTab: string - The active tab (record, music, advert)
//
// Collection: /users/{userId}
// Document ID: userId (matches auth.uid)
// Fields:
//   - uid: string (required)
//   - displayName: string (required)
//   - email: string (required)
//   - role: string (required, 'admin' or 'member')
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "Agnes2022kinyanjui@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidComment(data) {
      return data.keys().hasAll(['text', 'authorName', 'authorUid', 'timestamp']) &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 500 &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() <= 50 &&
             data.authorUid == request.auth.uid &&
             data.timestamp is timestamp;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 &&
             data.email is string &&
             data.role in ['admin', 'member'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'member' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /comments/{commentId} {
      allow read: if true; // Publicly readable for the live chat
      allow create: if isAuthenticated() && isValidComment(request.resource.data);
      allow delete: if isAdmin();
    }

    match /liveState/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /music/{musicId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /adverts/{advertId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
